{
  "name": "pbase",
  "version": "0.0.0",
  "description": "Scaffold a minimal TypeScript library starter",
  "type": "module",
  "private": true,
  "bin": {
    "pbase": "./dist/index.mjs"
  },
  "exports": {
    ".": "./dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "cac": "^6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1",
    "@types/bun": "latest",
    "tsdown": "^0.22",
    "typescript": "^6"
  },
  "files": ["dist", "template"]
}
